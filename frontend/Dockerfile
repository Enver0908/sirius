FROM node:20-alpine

WORKDIR /app

ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_SHOPIFY_API_KEY
ARG NEXT_PUBLIC_SHOPIFY_APP_HANDLE

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_SHOPIFY_API_KEY=$NEXT_PUBLIC_SHOPIFY_API_KEY
ENV NEXT_PUBLIC_SHOPIFY_APP_HANDLE=$NEXT_PUBLIC_SHOPIFY_APP_HANDLE

COPY package*.json ./
RUN npm install

COPY . .
RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "start"]
